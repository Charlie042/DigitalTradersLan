# Copy to server/.env
DATABASE_URL=
FRONTEND_URL=http://localhost:5173
PORT=3001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be Express — NOT http://localhost:5173/... (Vite). Register this exact URI in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

SESSION_SECRET=
